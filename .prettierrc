{
    "tabWidth": 4,
    "semi": true,
    "singleQuote": false,
    "trailingComma": "es5",
    "printWidth": 120,
    "plugins": ["@ianvs/prettier-plugin-sort-imports", "prettier-plugin-tailwindcss"],
    "importOrder": [
        "^react$",
        "^next",
        "",
        "<THIRD_PARTY_MODULES>",
        "",
        "^@/lib/(.*)$",
        "^@/contexts/(.*)$",
        "^@/hooks/(.*)$",
        "^@/app/_components/(.*)$",
        "^@/types(.*)$",
        "",
        "^[./]"
    ]
}
